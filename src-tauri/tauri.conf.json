{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "photogenic",
  "version": "0.1.0",
  "identifier": "com.fchery87.photogenic",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "photogenic",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "license": {
      "publicKey": "e548f635ca1c7c3806f67e2a7261a82faa6aa23dca1218f2ae67ec4f50282b9c",
      "algorithm": "ed25519",
      "description": "Public key for offline license signature verification. The corresponding private key is held by the license issuer."
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
